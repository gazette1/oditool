# ── Required ──
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable (optional — enables session persistence) ──
VITE_AIRTABLE_API_KEY=pat...
VITE_AIRTABLE_BASE_ID=app...

# ── Search Volume Provider (optional — defaults to Claude estimation) ──
# Options: "serpapi", "dataforseo", "claude"
VITE_SEARCH_PROVIDER=claude

# SerpAPI — $50/mo, real Google search data
# Sign up: https://serpapi.com
VITE_SERPAPI_KEY=

# DataForSEO — enterprise keyword volume
# Sign up: https://dataforseo.com
VITE_DATAFORSEO_LOGIN=
VITE_DATAFORSEO_PASSWORD=

# ── Google Drive (Engine v1.4.1) ──
# For Project Setup folder-ingest. Public folders only (Anyone with link).
# Setup: console.cloud.google.com → enable Drive API → create API key.
VITE_GOOGLE_DRIVE_API_KEY=
